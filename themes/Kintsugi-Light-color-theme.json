  "tokenColors": [
    {
      "name": "Default Text, Variables, Properties, Functions",
      "scope": [
        "text",
        "source",
        "variable",
        "meta.macro",
        "keyword.symbol",
        "keyword.operator",
        "meta.property-name",
        "constant.character",
        "entity.name.variable",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#2a2818"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "string.comment"],
      "settings": {
        "foreground": "#9a8858",
        "fontStyle": ""
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.template", "punctuation.definition.string"],
      "settings": {
        "foreground": "#3a6820"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#3848a8"
      }
    },
    {
      "name": "Keywords, Storage, Special Language Variables",
      "scope": [
        "keyword",
        "storage.modifier",
        "storage.type",
        "keyword.operator.new",
        "keyword.operator.expression.typeof.js",
        "entity.name.function.macro",
        "keyword.type.go",
        "keyword.operator.sizeof.c",
        "variable.language.self.rust",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#9a7820",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Types, Support, Other Entities",
      "scope": [
        "support",
        "entity.name",
        "constant.language",
        "constant.other.placeholder",
        "punctuation.definition.interpolation"
      ],
      "settings": {
        "foreground": "#5a6060"
      }
    },
    {
      "name": "Java Annotation",
      "scope": ["storage.type.annotation.java"],
      "settings": {
        "foreground": "#487870",
        "fontStyle": ""
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "entity.name.function.preprocessor",
        "entity.name.other.preprocessor.macro.predefined"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#8a4040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Link",
      "scope": "string.detected-link",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff: Header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#8a8878"
      }
    },
    {
      "name": "Diff: Deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#8a4040"
      }
    },
    {
      "name": "Diff: Inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#4a7a30"
      }
    },
    {
      "name": "Diff: Changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#9a7820"
      }
    },
    {
      "name": "Find in Files: Filename",
      "scope": "entity.name.filename.find-in-files",
      "settings": {
        "foreground": "#9a7820"
      }
    },
    {
      "name": "Markup: Bold & Heading",
      "scope": ["markup.bold", "markup.heading.markdown"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup: Italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup: Raw",
      "scope": ["markup.block.raw", "markup.inline.raw"],
      "settings": {
        "foreground": "#5a6060"
      }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation, delimiter, bracket, brace, paren, delimiter.tag, punctuation.tag, tag.html, tag.xml, meta.property-value punctuation.separator.key-value, punctuation.definition.metadata.md, string.link.md, meta.brace",
      "settings": {
        "foreground": "#8a8468"
      }
    }
  ],
  "semanticHighlighting": false
}
