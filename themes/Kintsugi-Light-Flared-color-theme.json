  "tokenColors": [
    {
      "name": "Default Text, Variables, Properties",
      "scope": ["text", "source", "variable"],
      "settings": {
        "foreground": "#3c3828"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.comment"],
      "settings": {
        "foreground": "#a4a09a"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "delimiter",
        "bracket",
        "brace",
        "paren",
        "delimiter.tag",
        "punctuation.tag",
        "tag.html",
        "tag.xml",
        "meta.property-value punctuation.separator.key-value",
        "punctuation.definition.metadata.md",
        "string.link.md",
        "meta.brace",
        "punctuation.definition.string",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#928e84"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "meta.property-value.keyword",
        "support.constant.property-value.keyword",
        "meta.preprocessor.keyword",
        "keyword.other.use",
        "keyword.other.function.use",
        "keyword.other.namespace",
        "keyword.other.new",
        "keyword.other.special-method",
        "keyword.other.unit",
        "keyword.other.use-as"
      ],
      "settings": {
        "foreground": "#b84020",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage & Bolded Items",
      "scope": [
        "storage",
        "entity.name.tag",
        "keyword.operator.new",
        "variable.language.this",
        "variable.language.self",
        "meta.qualified_type.cpp entity.name.type.cpp"
      ],
      "settings": {
        "foreground": "#9a7820",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Language-Specific Constructs",
      "scope": [
        "meta.definition.variable.java storage.type.java",
        "meta.catch.parameters.java storage.type.java",
        "meta.import.java storage.modifier.import.java",
        "meta.function-call.python meta.function-call.generic.python",
        "meta.function.python support.variable.magic.python"
      ],
      "settings": {
        "foreground": "#686e70"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#b86820",
        "fontStyle": ""
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "meta.property-value.string",
        "support.constant.property-value.string",
        "meta.structure.dictionary.value.json string.quoted.double.json",
        "meta.structure.dictionary.json string.quoted.double.json",
        "meta.preprocessor string",
        "string.template"
      ],
      "settings": {
        "foreground": "#a85030"
      }
    },
    {
      "name": "String Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#686e70"
      }
    },
    {
      "name": "Primitive Literals (Numbers, Booleans, etc)",
      "scope": [
        "constant.numeric",
        "meta.property-value.numeric",
        "support.constant.property-value.numeric",
        "meta.property-value.color",
        "support.constant.property-value.color",
        "constant.language"
      ],
      "settings": {
        "foreground": "#a87820"
      }
    },
    {
      "name": "User-defined names (Functions, Classes, etc)",
      "scope": [
        "constant.character",
        "constant.other",
        "entity.name.function",
        "entity.name.class",
        "entity.other.inherited-class",
        "entity.other.attribute-name",
        "entity.name",
        "entity.name.type.class",
        "entity.other.attribute-name.html",
        "support.type.property-name",
        "entity.name.tag.table",
        "meta.structure.dictionary.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#506870"
      }
    },
    {
      "name": "Un-bold specific storage types",
      "scope": [
        "storage.type.annotation.java",
        "storage.type.java",
        "storage.type.object.array.java",
        "entity.name.type",
        "meta.qualified_type.cpp entity.name.type.cpp",
        "meta.import.java storage.modifier.import.java"
      ],
      "settings": {
        "fontStyle": ""
      }
    },
    {
      "name": "Pointer, access, etc",
      "scope": ["meta.ptr", "meta.pointer", "meta.address", "meta.array.cxx"],
      "settings": {
        "foreground": "#b87040"
      }
    },
    {
      "name": "Preprocessor",
      "scope": ["meta.preprocessor"],
      "settings": {
        "foreground": "#686e70"
      }
    },
    {
      "name": "Library Support",
      "scope": [
        "support.type",
        "support.class",
        "support.function",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b86820"
      }
    },
    {
      "name": "Generic Types (Containers)",
      "scope": ["storage.type.generic", "entity.name.type.template.cpp"],
      "settings": {
        "foreground": "#b86820",
        "fontStyle": ""
      }
    },
    {
      "name": "Compiler Metadata & Attributes (Annotations, Lifetimes, Decorators)",
      "scope": [
        "storage.type.annotation.java",
        "meta.type.annotation.ts",
        "entity.name.type.lifetime",
        "punctuation.definition.lifetime",
        "meta.attribute.rust",
        "punctuation.definition.attribute.rust",
        "meta.decorator",
        "punctuation.definition.decorator",
        "entity.name.function.decorator",
        "meta.decorator.ts variable.other.readwrite.ts"
      ],
      "settings": {
        "foreground": "#487870"
      }
    },
    {
      "name": "JSX/TSX Tags",
      "scope": ["entity.name.tag.tsx", "entity.name.tag.jsx"],
      "settings": {
        "foreground": "#9a7820",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": {
        "foreground": "#8a5050",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Diff: Header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#8a8878"
      }
    },
    {
      "name": "Diff: Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#8a5050"
      }
    },
    {
      "name": "Diff: Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#5a8a40"
      }
    },
    {
      "name": "Diff: Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#9a7820"
      }
    },
    {
      "name": "Markdown: Title Hash",
      "scope": [
        "punctuation.definition.heading.md",
        "entity.name.type.md",
        "beginning.punctuation"
      ],
      "settings": {
        "foreground": "#686e70"
      }
    },
    {
      "name": "Markdown: Titles & Bold Text",
      "scope": ["markup.heading", "entity.name.section", "markup.bold"],
      "settings": {
        "foreground": "#9a7820",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown: Raw Code",
      "scope": [
        "markup.raw",
        "markup.inline.raw",
        "markup.fenced",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#a85030"
      }
    },
    {
      "name": "Markdown: Link",
      "scope": [
        "markup.link",
        "string.other.link.title",
        "string.other.link.description",
        "meta.link.inline",
        "meta.image.inline"
      ],
      "settings": {
        "foreground": "#686e70"
      }
    },
    {
      "name": "Makefile Variables",
